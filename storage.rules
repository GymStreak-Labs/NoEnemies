rules_version = '2';

// Mirrors the Firestore rules: every user can only touch their own subtree.
// Audio files live at users/{uid}/audio/journal/{entryId}.wav — the recursive
// match covers that plus any future audio paths we add (voice sessions, etc.).
service firebase.storage {
  match /b/{bucket}/o {
    match /users/{uid}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
